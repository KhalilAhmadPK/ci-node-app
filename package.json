{
  "name": "ci-node-app",
  "version": "1.0.0",
  "description": "Simple Node.js app with GitHub Actions CI pipeline",
  "main": "index.js",
  "scripts": {
    "start":       "node index.js",
    "test":        "jest --coverage",
    "test:watch":  "jest --watch",
    "lint":        "eslint src/ tests/",
    "lint:fix":    "eslint src/ tests/ --fix",
    "build":       "node -e \"require('./src/app'); console.log('Build successful');\""
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^8.57.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}